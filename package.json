{
  "name": "figma-bridge",
  "version": "2.0.0",
  "description": "Agent-Driven Figma-to-Code CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "figma-bridge": "./dist/bin/figma-bridge.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "figma",
    "code-generation",
    "react",
    "tailwind",
    "cli",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "delta-e": "^0.0.8",
    "fast-glob": "^3.3.3",
    "inquirer": "^12.4.0",
    "jiti": "^2.4.2",
    "ora": "^8.2.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.50.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.5.3",
    "ts-morph": "^25.0.0",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.13.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0"
  }
}
